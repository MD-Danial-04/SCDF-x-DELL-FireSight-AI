# Coordinator API (job submission)
# Local development:
VITE_COORDINATOR_URL=http://localhost:8080
# Production (OpenShift):
# VITE_COORDINATOR_URL=https://firesight-coordinator-firetrack.apps.innovate.sg-aie.com
VITE_WEB_API_KEY=dev-web-key

# Supabase Realtime (job status updates) and floorplan drafts storage.
# The floorplan editor stores named drafts in a `floorplan_drafts` table.
# See docs/floorplan-drafts-supabase.sql for the schema + RLS setup.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Singpass / Myinfo retrieval for tenant + interviewee particulars.
# `mock` (default) uses built-in fake personas entirely in the browser.
# `live` is reserved for a future coordinator-backed MyInfo v4 integration.
VITE_SINGPASS_MODE=mock
